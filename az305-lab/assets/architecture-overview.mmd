    %% ── Cross-Module Connections ───────────────────────────────

    %% Foundation → all modules (diagnostic settings)
    VNet --> KVPE
    VNet --> StorPE
    VNet --> SQLPE
    VNet --> AVSet
    VNet --> AZVM
    VNet --> VM

    LAW -.->|diagnostic logs| KV
    LAW -.->|diagnostic logs| SQLSrv
    LAW -.->|diagnostic logs| Cosmos
    LAW -.->|diagnostic logs| ADF
    LAW -.->|diagnostic logs| EH
    LAW -.->|diagnostic logs| SBus
    LAW -.->|diagnostic logs| APIM
    LAW -.->|diagnostic logs| WebNSG
    LAW -.->|workspace| AppIns

    %% HA/DR load balancer → VMs
    PubLB --> AVSet
    IntLB --> AVSet
    PubLB --> AZVM
    RSV -.->|backup| AVSet

    %% Networking peering
    VNet <-->|"VNet Peering"| Spoke

    %% Data Integration flow
    ADF --> Pipeline
    Pipeline --> DLBronze
    DLBronze --> DLSilver
    DLSilver --> DLGold
    EGTopic08 -.->|trigger| Pipeline

    %% Database relationships
    SQLSrv --> SQLBasic
    SQLSrv --> SQLSless
    SQLSrv --> ElasticPool

    %% Governance scope
    Policy -.->|assigned| MG
    RBAC -.->|assigned| MG

    %% Identity → resources
    ManagedId02 -.->|access| KV

    %% Compute → registry
    ACR -.->|pull image| ACI

    %% App Architecture messaging flow
    EGTopic -.->|events| EH
    EH -.->|stream| FuncApp
    SBus -.->|dequeue| AppSvc
    APIM -.->|route| AppSvc
    Redis -.->|cache| AppSvc

    %% Key Vault → Private Endpoint → VNet
    KVPE --> VNet
    StorPE --> VNet
    SQLPE --> VNet

