# =============================================================================
# AZ-305 Lab — Module 07: Database Solutions — Example Variable Values
# =============================================================================
# Copy this file to terraform.tfvars and adjust values for your environment.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# You MUST supply the foundation module outputs. Run Module 00 first, then
# copy its output values here or use a data source / remote state.
# =============================================================================

# Azure region — must match the foundation module's region.
location = "eastus"

# Naming prefix — must match what you used in Module 00.
prefix = "certlab"

# SQL Server administrator username (password is auto-generated).
sql_admin_username = "sqladmin"

# Your public IP for SQL Server firewall access.
# Find your IP: curl -s https://api.ipify.org
# Set to "0.0.0.0" to skip (rely on private endpoint / Azure services only).
allowed_client_ip = "0.0.0.0"

# --- Values from Module 00 outputs (run `terraform output` in 00-foundation) ---

# foundation_resource_group_name = "certlab-foundation-rg-abc123"
# vnet_id                        = "/subscriptions/.../resourceGroups/.../providers/Microsoft.Network/virtualNetworks/certlab-vnet-abc123"
# database_subnet_id             = "/subscriptions/.../resourceGroups/.../providers/Microsoft.Network/virtualNetworks/.../subnets/database"
# log_analytics_workspace_id     = "/subscriptions/.../resourceGroups/.../providers/Microsoft.OperationalInsights/workspaces/certlab-law-abc123"

# Tags — override or extend the defaults.
tags = {
  Lab        = "AZ-305"
  CostCenter = "CertStudy"
  ManagedBy  = "Terraform"
  Owner      = "yourname@example.com"
}
